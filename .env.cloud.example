HOST="0.0.0.0"
PORT="8000"

# Point this to PostgreSQL running on the Hong Kong box or to a managed database.
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/crystal_prompter"

OPENAI_API_KEY="CHANGE_ME"
OPENAI_MODEL="gpt-5-mini"
D_ID_API_KEY="CHANGE_ME"
D_ID_BASE_URL="https://api.d-id.com"

# Linux/cloud TTS fallback uses OpenAI audio/speech.
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_TTS_VOICE="coral"

# Fixed avatar image already stored on the Hong Kong instance.
AVATAR_SOURCE_IMAGE="/root/MuseTalk/input/daniel_mobile_even.png"

# Run Ditto locally on the same Hong Kong machine. No scp/ssh hops.
AVATAR_GENERATOR_COMMAND="/opt/miniforge3/bin/conda run -n ditto python /root/MuseTalk/ditto-talkinghead/inference.py --data_root /root/MuseTalk/ditto-talkinghead/checkpoints/ditto_pytorch --cfg_pkl /root/MuseTalk/ditto-talkinghead/checkpoints/ditto_cfg/v0.4_hubert_cfg_pytorch.pkl --audio_path {audio_path} --source_path {source_path} --output_path {output_path}"
